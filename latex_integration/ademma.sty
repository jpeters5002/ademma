\newcommand{\ademmaclassical}[1]
{
	\StrDel{#1}{^}[\ademmafilenametemp]
	\ademmaimpl{#1}{cl}{\ademmafilenametemp.cl.tex}
}

\newcommand{\ademmarmotivic}[1]
{
	%\saveexpandmode\noexpandarg
	\StrSubstitute{#1}{\\}{:}[\ademmasanitizedbackslashtemp]
	\StrDel{#1}{^}[\ademmafilenametemp1]
	\StrDel{\ademmafilenametemp1}{\\}[\ademmafilenametemp2]
	%\restoreexpandmode
	\ademmaimpl{\ademmasanitizedbackslashtemp}{rm}{\ademmafilenametemp2.rm.tex}
}

\newcommand{\testthing}[1]
{
