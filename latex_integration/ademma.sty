\usepackage{xstring}

%helper macros

\makeatletter
\newcommand{\replacebackslashwithB}[2]{{\escapechar=`B 
  \xdef#2{\expandafter\zap@space\detokenize\expandafter{#1} \@empty}}}
\makeatother

%main implementation

% calculation-input, setting, filename
\newcommand\ademmaimpl[3]
{
	\IfFileExists{#3}
	{
		\input{#3}
	}
    {
        {\immediate\write18{mkdir -p \string~/.ademma}}
        {\immediate\write18{ademma --only-cli --setting #2 '#1' > #3 2> /home/brian/latex/ademmastatuserrmsg.txt}}
        \IfFileExists{#3}
		{
		    \input{#3}
		}
		{
		    \errmessage{Error running ademma with calculation-input '#1': see file /home/brian/latex/ademmastatuserrmsg.txt for more information}
		}
    }
}

%user-friendly macros

\newcommand{\ademmaclassical}[1]
{
    \replacebackslashwithB{#1}{\ademmasanitizedbackslashtemp}
	\StrDel{\ademmasanitizedbackslashtemp}{ }[\ademmafilenametemp1]
	\StrDel{\ademmafilenametemp1}{\\\\}[\ademmafilenametemp2]
    \newcommand{\ademmafullpathtemp}{\string~/.ademma/\ademmafilenametemp2.cl.tex}
	\ademmaimpl{\ademmasanitizedbackslashtemp}{cl}{\ademmafullpathtemp}
}

\newcommand{\ademmarmotivic}[1]
{
    \replacebackslashwithB{#1}{\ademmasanitizedbackslashtemp}
	\StrDel{\ademmasanitizedbackslashtemp}{ }[\ademmafilenametemp1]
	\StrDel{\ademmafilenametemp1}{\\\\}[\ademmafilenametemp2]
    \newcommand{\ademmafullpathtemp}{\string~/.ademma/\ademmafilenametemp2.rm.tex}
    \ademmaimpl{\ademmasanitizedbackslashtemp}{rm}{\ademmafullpathtemp}
}

