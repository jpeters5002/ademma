    {
        #2 =
    }{}
    \replacebackslashwithB{#2}{\ademmasanitizedbackslashtemp}
    \StrDel{\ademmasanitizedbackslashtemp}{ }[\ademmafilenametempA]
    \StrDel{\ademmafilenametempA}{\\\\}[\ademmafilenametempB]
    \ademmaimplproxy{\ademmasanitizedbackslashtemp}{cl}{\ademmafilenametempB.cl.tex}
