\newcommand{\ademmaclassical}[1]
{
	\StrDel{#1}{ }[\ademmafilenametemp1]
	%\StrDel{\ademmafilenametemp1}{\\\\}[\ademmafilenametemp2]
	\ademmaimpl{#1}{cl}{\ademmafilenametemp1.cl.tex}
}

\newcommand{\ademmarmotivic}[1]
{
    \replacebackslashwithB{#1}{\ademmasanitizedbackslashtemp}
	\StrDel{\ademmasanitizedbackslashtemp}{ }[\ademmafilenametemp1]
	%\StrDel{\ademmafilenametemp1}{\\\\}[\ademmafilenametemp2]
	\ademmaimpl{\ademmasanitizedbackslashtemp}{rm}{\ademmafilenametemp1.rm.tex}
}

