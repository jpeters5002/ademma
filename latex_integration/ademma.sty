\usepackage{xstring}

%helper macros

\makeatletter
\newcommand{\replacebackslashwithB}[2]{{\escapechar=`B
  \xdef#2{\expandafter\detokenize\expandafter{#1} \@empty}}}
\makeatother

%main implementation macros

% #1               , #2     , #3               , #4                , #5                      , #6
% calculation-input, setting, fullpathcachefile, fullpatherroutfile, fullpatherrindicatorfile, dir
\newcommand{\ademmaimpl}[6]
{
    \IfFileExists{#3}
    {
        \input{#3}
    }
    {
        {\immediate\write18{mkdir -p #6}}
        {\immediate\write18{ademma --only-cli --setting #2 "#1" > #3 2> #4 \detokenize{||} touch #5}}
        \IfFileExists{#5}
        {
            {\immediate\write18{rm -f #5}}
            {\immediate\write18{rm -f #3}}
            \errmessage{Error running ademma with calculation-input '#1': see file '#4' for more information}
        }
        {
            \IfFileExists{#3}
            {
                {\immediate\write18{rm -f #4}}
                \input{#3}
            }
            {
                \errmessage{Error running ademma: '-shell-escape' option required}
            }
        }
    }
}

% calculation-input, setting, cache-filename
\newcommand{\ademmaimplproxy}[3]
{
    \newcommand{\ademmadir}{\detokenize{~/.ademma}}
    \newcommand{\ademmafullpathcachefile}{\detokenize{~/.ademma/}#3}
    \newcommand{\ademmafullpatherroutfile}{\detokenize{~/.ademma/ademmastatuserrmsg.txt}}
    \newcommand{\ademmafullpatherrindicatorfile}{\detokenize{~/.ademma/ademmaerror.tmp}}
    \ademmaimpl{#1}{#2}{\ademmafullpathcachefile}{\ademmafullpatherroutfile}{\ademmafullpatherrindicatorfile}{\ademmadir}
}

% calculation-input, setting
\newcommand{\ademmaimplproxyproxy}[2]
{
    \replacebackslashwithB{#1}{\ademmasanitizedinputtempA}%                                    '\' -> 'B'
    \StrSubstitute{\ademmasanitizedinputtempA}{B}{ObslashO}[\ademmasanitizedinputtempB]%       'B' -> 'ObslashO' - somehow this one doesn't work and idk why
    \StrSubstitute{\ademmasanitizedinputtempB}{+}{OplusO}[\ademmasanitizedinputtempC]%         '+' -> 'OplusO'
    \StrSubstitute{\ademmasanitizedinputtempC}{*}{OasteriskO}[\ademmasanitizedinputtempD]%     '*' -> 'OasteriskO'
    \StrSubstitute{\ademmasanitizedinputtempD}{\string(}{OlparenO}[\ademmasanitizedinputtempE]%'(' -> 'OlparenO'
    \StrSubstitute{\ademmasanitizedinputtempE}{\string)}{OrparenO}[\ademmasanitizedinputtempF]%')' -> 'OrparenO'
    \StrSubstitute{\ademmasanitizedinputtempF}{\string^}{OcaretO}[\ademmasanitizedinputtempG]% '^' -> 'OcaretO'
    \StrDel{\ademmasanitizedinputtempG}{ }[\ademmafilenametempA]%                           rm spaces
    \StrDel{\ademmafilenametempA}{\\\\}[\ademmafilenametempB]%                              rm newlines
    \ExpandArgs{e}\StrDel{\ademmafilenametempB}{\string{\iffalse}\fi}[\ademmafilenametempC]%rm '{' - shoutouts to https://tex.stackexchange.com/a/748419
    \ExpandArgs{e}\StrDel{\ademmafilenametempC}{\iffalse{\fi\string}}[\ademmafilenametempD]%rm '}' - shoutouts to https://tex.stackexchange.com/a/748419
    \ademmaimplproxy{\ademmasanitizedinputtempG}{#2}{\ademmafilenametempD.#2.tex}
}

%user-friendly macros

% #1                                                       , #2
% (optional) print-calculation-input-equals [default: true], calculation-input
\newcommand{\ademmaclassical}[2][true]
{
    \IfStrEq{#1}{true}
    {
        #2 =
    }{}
    \ademmaimplproxyproxy{#2}{cl}
}

